{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=persons;Username=postgres;Password=root"
  },
  "LoggingConfiguration": {
    "MinimumLevel": "Information",
    "EnableConsole": true,
    "EnableFile": true,
    "LogFilePath": "logs/app-.log",
    "RetentionDays": 30,
    "ApplicationInsightsConnectionString": "",
    "SentryDsn": ""
  },
  "RequestLogging": {
    "LogRequestBody": true,
    "LogResponseBody": true,
    "MaxBodyLogLength": 4096,
    "ExcludedPaths": ["/health", "/metrics", "/favicon.ico", "/swagger"],
    "SensitiveHeaders": ["Authorization", "X-Api-Key", "Cookie", "Set-Cookie", "X-Auth-Token"]
  },
  "PiiMasking": {
    "EnableEmailMasking": true,
    "EnableCreditCardMasking": true,
    "EnablePhoneMasking": true,
    "EnableSsnMasking": true,
    "SensitiveFieldNames": ["password", "pwd", "secret", "token", "apikey", "api_key", "ssn", "creditcard", "credit_card", "cvv", "pin"]
  }
}
